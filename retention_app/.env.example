OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Local LLM (Ollama). Set USE_LOCAL_LLM=true to bypass OpenRouter entirely.
USE_LOCAL_LLM=false
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=braintrashtogold-qwen
WHISPER_MODEL=base

ENABLE_EMAIL_REMINDERS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

ENABLE_SYSTEM_NOTIFICATIONS=false
APP_BASE_URL=http://localhost:8000
TIMEZONE=America/New_York
